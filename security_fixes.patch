+// Hardened HTTP Clients
+fn get_paypal_client() -> Result<reqwest::Client, Box<dyn std::error::Error>> {
+    let cert = reqwest::Certificate::from_pem(PAYPAL_CERT_PEM)?;
+    Ok(reqwest::Client::builder().tls_built_in_root_certs(false).add_root_certificate(cert).https_only(true).build()?)
+}
+
+fn get_acme_client() -> Result<reqwest::Client, Box<dyn std::error::Error>> {
+    let cert = reqwest::Certificate::from_pem(GOOGLE_CA_PEM)?;
+    Ok(reqwest::Client::builder().tls_built_in_root_certs(false).add_root_certificate(cert).build()?)
+}
