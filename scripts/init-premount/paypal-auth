#!/bin/sh
set -x

PREREQ=""
prereqs() {
    echo "$PREREQ"
}

case $1 in
    prereqs)
        prereqs
        exit 0
        ;;
esac

echo "--- PAYPAL AUTH VM BOOT (CONSOLE) ---"

# 1. Load network drivers for GCP GVNIC and Virtio
echo "Loading GCP Virtual NIC and Virtio drivers..."
modprobe gve || true
modprobe virtio_net || true
udevadm settle

# Ensure /dev/tpm0 exists (vTPM)
if [ ! -c /dev/tpm0 ]; then
    echo "WARNING: /dev/tpm0 not found. Attempting to load tpm drivers..."
    modprobe tpm_tis || true
    modprobe tpm_tis_core || true
fi

# 2. Bring up the network via ipconfig (klibc)
# -t 60:# Bring up network
echo "Bringing up network (any interface)..."
# Use 'any' to handle dynamic interface names (eth0/ens3/enp0s1)
ipconfig -t 60 any

# 3. Wait for GCP Metadata service to become available
echo "Waiting for GCP metadata service (http://metadata.google.internal)..."
for i in $(seq 1 30); do
    if curl -sf -m 2 -H "Metadata-Flavor: Google" http://metadata.google.internal/computeMetadata/v1/instance/ >/dev/null 2>&1; then
        echo "Metadata service is UP"
        UP=1
        break
    fi
    echo "Metadata service still down (attempt $i)..."
    sleep 1
done

if [ -z "$UP" ]; then
    echo "ERROR: Metadata service timed out after 30 seconds"
fi

# 4. Fetch environment from metadata attributes
echo "Fetching session metadata..."
fetch_metadata() {
    curl -sf -H "Metadata-Flavor: Google" \
        "http://metadata.google.internal/computeMetadata/v1/instance/attributes/${1}"
}

SECRET_NAME=$(fetch_metadata "tee-env-SECRET_NAME")
TLS_CACHE_SECRET=$(fetch_metadata "tee-env-TLS_CACHE_SECRET")
RUST_LOG=$(fetch_metadata "tee-env-RUST_LOG")

echo "SECRET_NAME: ${SECRET_NAME:-[MISSING]}"
echo "TLS_CACHE_SECRET: ${TLS_CACHE_SECRET:-[MISSING]}"

# Export to environment for the Rust app
export SECRET_NAME
export TLS_CACHE_SECRET
export RUST_LOG="${RUST_LOG:-debug}"

# 5. Measure the binary into PCR 15 before execution (attested boot)
# The binary is at /usr/bin/paypal-auth-vm (where copy_exec placed it)
if [ -f /init ]; then
    BIN_HASH=$(sha256sum /init | awk '{print $1}')
    echo "Attesting binary (hash: $BIN_HASH) into vTPM PCR 15..."
    if [ -c /dev/tpm0 ]; then
        tpm2_pcrextend 15:sha256=$BIN_HASH || echo "tpm2_pcrextend failed!"
    else
        echo "ERROR: Cannot attest binary, /dev/tpm0 missing"
    fi
else
    echo "ERROR: Binary /usr/bin/paypal-auth-vm not found!"
fi

# 6. Final checks
export RUST_LOG="${RUST_LOG:-debug}"

# 7. The initramfs-tools /init script will continue and eventually exec our Rust binary
# which is at /init (symlink to /usr/bin/paypal-auth-vm)
echo "Setup complete. The Rust binary at /init will be executed as PID 1."
