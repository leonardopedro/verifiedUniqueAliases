#!/bin/sh
set -e

PREREQ=""
prereqs() {
    echo "$PREREQ"
}

case $1 in
    prereqs)
        prereqs
        exit 0
        ;;
esac

. /usr/share/initramfs-tools/hook-functions

# --- Rust binary → /init (PID 1) ---
# copy_exec bundles the binary + all its shared libraries (glibc, etc.)
if [ -f "/tmp/paypal-auth-vm-bin" ]; then
    BIN_SRC="/tmp/paypal-auth-vm-bin"
elif [ -f "./target/x86_64-unknown-linux-gnu/release/paypal-auth-vm" ]; then
    BIN_SRC="./target/x86_64-unknown-linux-gnu/release/paypal-auth-vm"
elif [ -f "$HOME/paypal-auth-vm-bin" ]; then
    BIN_SRC="$HOME/paypal-auth-vm-bin"
else
    echo "❌ ERROR: Could not find paypal-auth-vm binary"
    exit 1
fi

# Place binary at /init (PID 1) with all glibc dependencies bundled
copy_exec "$BIN_SRC" /init

# --- iproute2 (ip command) for applying DHCP lease ---
copy_exec /sbin/ip /sbin/ip

# --- TPM2 tools for attestation ---
copy_exec /usr/bin/tpm2_pcrextend /usr/bin/tpm2_pcrextend
copy_exec /usr/bin/tpm2_createprimary /usr/bin/tpm2_createprimary
copy_exec /usr/bin/tpm2_create /usr/bin/tpm2_create
copy_exec /usr/bin/tpm2_load /usr/bin/tpm2_load
copy_exec /usr/bin/tpm2_unseal /usr/bin/tpm2_unseal
copy_exec /usr/bin/tpm2_quote /usr/bin/tpm2_quote
copy_exec /usr/bin/tpm2_createak /usr/bin/tpm2_createak
copy_exec /usr/bin/tpm2_createpolicy /usr/bin/tpm2_createpolicy

# --- Other utilities ---
copy_exec /usr/bin/curl /usr/bin/curl
copy_exec /usr/bin/sha256sum /usr/bin/sha256sum

# --- CA certificates (needed for ACME / GCP Secret Manager TLS) ---
mkdir -p "${DESTDIR}/etc/ssl/certs"
cp -rL /etc/ssl/certs/. "${DESTDIR}/etc/ssl/certs/"

# --- OpenSSL config ---
if [ -f /etc/ssl/openssl.cnf ]; then
    mkdir -p "${DESTDIR}/etc/ssl"
    cp /etc/ssl/openssl.cnf "${DESTDIR}/etc/ssl/openssl.cnf"
fi

# --- Working directories for TLS certificates ---
mkdir -p "${DESTDIR}/run/certs"
mkdir -p "${DESTDIR}/tmp/acme-challenge"
mkdir -p "${DESTDIR}/etc"
